{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":automergePatch",
    ":disableRateLimiting",
    ":semanticCommits",
    ":semanticCommitScope"
  ],
  "labels": ["dependencies"],
  "automerge": true,
  "automergeType": "pr",
  "platformAutomerge": true,
  "packageRules": [
    {
      "description": "Auto-merge all minor and patch updates",
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "description": "Group Spring Boot related updates together",
      "matchManagers": ["gradle"],
      "matchPackagePrefixes": ["org.springframework.boot", "org.springframework.ai"],
      "groupName": "spring",
      "group": {
        "branchTopic": "group-spring"
      }
    },
    {
      "description": "Group Gradle wrapper updates",
      "matchManagers": ["gradle-wrapper"],
      "groupName": "gradle-wrapper",
      "group": {
        "branchTopic": "group-gradle-wrapper"
      }
    },
    {
      "description": "Group Java LTS updates",
      "matchManagers": ["docker-version"],
      "matchPackageNames": ["eclipse-temurin"],
      "groupName": "java-lts"
    },
    {
      "description": "Auto-merge GitHub Actions",
      "matchManagers": ["github-actions"],
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "description": "Bump major versions but don't auto-merge",
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "labels": ["major-update"]
    }
  ],
  "gradle-wrapper": {
    "enabled": true
  },
  "prHourlyLimit": 0,
  "prConcurrentLimit": 20,
  "suppressNotifications": ["prEditedNotification", "prIgnoreNotification"],
  "timezone": "America/Chicago",
  "schedule": ["before 5am on monday"]
}
